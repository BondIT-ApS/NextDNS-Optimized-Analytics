# EditorConfig — cross-editor formatting consistency
# https://editorconfig.org
root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python (backend)
[*.py]
indent_size = 4
max_line_length = 88

# TypeScript / JavaScript / React
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
max_line_length = 120

# Web / Config files
[*.{json,jsonc,css,scss,html,svg}]
indent_size = 2

# YAML (workflows, k8s manifests, docker-compose)
[*.{yml,yaml}]
indent_size = 2

# Markdown / Documentation
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Dockerfiles
[Dockerfile*]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# TOML (pyproject.toml, etc.)
[*.toml]
indent_size = 4

# Makefiles require tabs
[Makefile]
indent_style = tab
indent_size = 4
